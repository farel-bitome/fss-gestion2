{
  "name": "fss-gestion",
  "version": "1.0.0",
  "description": "FSS-GESTION - gestion des agents, badges, paie et alertes",
  "main": "main.js",
  "author": "FALLSERVICES ET SOLUTIONS",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.fallservicesetsolutions.fssgestion",
    "productName": "FSS-GESTION",
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
      "main.js",
      "preload.js",
      "FSS-GESTION.html"
    ]
  }
}
